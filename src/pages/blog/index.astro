---
import PostCard from '../../components/PostCard.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';
import { getPublishedPosts, postPathFromId } from '../../lib/posts';
import SiteShell from '../../layouts/SiteShell.astro';

const posts = await getPublishedPosts();
const now = new Date();
const SEVEN_DAYS_MS = 7 * 24 * 60 * 60 * 1000;

function isNew(pubDate: Date | string): boolean {
	const pub = pubDate instanceof Date ? pubDate : new Date(pubDate);
	return now.getTime() - pub.getTime() < SEVEN_DAYS_MS;
}
---

<SiteShell title={SITE_TITLE} description={SITE_DESCRIPTION} image="/images/og-blog.jpg">
	<section class="blog-list">
		<h1>All Posts</h1>
		<ul>
			{
				posts.map((post) => (
					<li>
						<PostCard
							href={postPathFromId(post.id)}
							title={post.data.title}
							description={post.data.summary || post.data.description}
							pubDate={post.data.pubDate}
							tags={post.data.tags}
							isNew={isNew(post.data.pubDate)}
						/>
					</li>
				))
			}
		</ul>
	</section>
</SiteShell>

<style>
	.blog-list {
		padding-bottom: var(--space-3);
	}

	.blog-list h1 {
		margin-bottom: var(--space-5);
		max-width: 12ch;
	}

	.blog-list ul {
		list-style: none;
		padding: 0;
		margin: 0;
		display: grid;
		gap: var(--space-4);
		grid-template-columns: repeat(auto-fill, minmax(min(100%, 320px), 1fr));
	}

	.blog-list li:first-child {
		grid-column: 1 / -1;
	}
</style>
