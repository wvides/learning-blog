---
import PostCard from '../components/PostCard.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { withBase } from '../lib/paths';
import { postPathFromId } from '../lib/posts';
import { getPostsByTopic } from '../lib/tags';
import SiteShell from '../layouts/SiteShell.astro';

const topics = await getPostsByTopic(3);
---

<SiteShell title={SITE_TITLE} description={SITE_DESCRIPTION} image="/images/og-home.jpg">
	<section class="hero">
		<div class="hero-copy">
			<h1>{SITE_TITLE}</h1>
			<p class="mission">
				I build <span class="accent">infrastructure and platform systems</span> and help teams ship
				<span class="accent">reliable products at scale</span>.
			</p>
			<p class="sublead">
				Here I share practical notes on platform architecture and how I'm upleveling my AI and
				agent-building skills.
			</p>
		</div>
	</section>

	{
		topics.map((topic) => (
			<section class="topic-group">
				<div class="section-head">
					<div>
						<h2>{topic.name}</h2>
						<p class="topic-desc">{topic.description}</p>
					</div>
					<a href={withBase(`/tags/${topic.slug}/`)}>See all</a>
				</div>
				<ul>
					{topic.posts.map((post) => (
						<li>
							<PostCard
								href={postPathFromId(post.id)}
								title={post.data.title}
								description={post.data.summary || post.data.description}
								pubDate={post.data.pubDate}
								tags={post.data.tags}
							/>
						</li>
					))}
				</ul>
			</section>
		))
	}
</SiteShell>

<style>
	.hero {
		display: grid;
		grid-template-columns: minmax(0, 1fr);
		gap: var(--space-3);
		padding-bottom: var(--space-7);
	}

	.hero-copy {
		max-width: 760px;
		display: grid;
		gap: var(--space-3);
	}

	.hero-copy h1 {
		margin: 0;
		font-size: clamp(1.65rem, 1.42rem + 0.9vw, 2.35rem);
		line-height: 1.05;
		letter-spacing: 0.01em;
	}

	.hero-copy .accent {
		color: var(--link);
	}

	.hero-copy p {
		margin: 0;
		max-width: 42ch;
	}

	.hero-copy .mission {
		font-size: clamp(1.16rem, 1rem + 0.85vw, 1.9rem);
		line-height: 1.18;
		font-weight: 500;
		color: var(--text-strong);
	}

	.hero-copy .sublead {
		font-size: 0.98rem;
		color: color-mix(in srgb, var(--text-muted), var(--text-strong) 10%);
	}

	.topic-group {
		margin-bottom: var(--space-7);
	}

	.section-head {
		display: flex;
		align-items: baseline;
		justify-content: space-between;
		gap: var(--space-3);
		margin-bottom: var(--space-5);
	}

	.section-head h2 {
		margin: 0;
	}

	.topic-desc {
		margin: var(--space-1) 0 0;
		font-size: 0.92rem;
		color: var(--text-muted);
		max-width: 48ch;
	}

	.section-head a {
		display: inline-flex;
		align-items: center;
		flex-shrink: 0;
		padding: 0.34rem 0.68rem;
		border-radius: 999px;
		border: 1px solid color-mix(in srgb, var(--line-subtle), var(--text-strong) 8%);
		text-decoration: none;
		background: color-mix(in srgb, var(--panel-bg), white 30%);
	}

	.topic-group ul {
		list-style: none;
		padding: 0;
		margin: 0;
		display: grid;
		gap: var(--space-4);
	}
</style>
